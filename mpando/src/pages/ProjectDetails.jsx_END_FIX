                </div>
            )}
        </div>

        <ProjectEditModal
            isOpen={isEditModalOpen}
            projectData={editFormData}
            contractors={siteEngineers}
            onClose={closeEditModal}
            onChange={handleEditFormChange}
            onSave={handleUpdateProject}
        />
      </main>
    </div>
  );
}

export default ProjectDetails;
